# HTTP clone: create repo, seed via filesystem, clone over HTTP, verify files
mkrepo httpclonerepo

git init local-repo
cp README.md local-repo/README.md
cp hello.txt local-repo/hello.txt
cp main.go local-repo/src/main.go
git -C local-repo add .
git -C local-repo commit -m initial

git -C local-repo push file://$REPOS/httpclonerepo.git master

exec git clone $MURL/httpclonerepo clone-dir
exists clone-dir/README.md
exists clone-dir/hello.txt
exists clone-dir/src/main.go
exec cat clone-dir/hello.txt
stdout 'hello world'

-- README.md --
# Test Repo

A test repository.
-- hello.txt --
hello world
-- main.go --
package main

func main() {}
