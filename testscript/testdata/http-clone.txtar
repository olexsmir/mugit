# HTTP clone: create repo, seed via filesystem, clone over HTTP, verify files
mkrepo httpclonerepo

exec git init local-repo
exec git -C local-repo config user.email "test@test.local"
exec git -C local-repo config user.name "Test User"
cp README.md local-repo/README.md
cp hello.txt local-repo/hello.txt
cp main.go local-repo/src/main.go
exec git -C local-repo add .
exec git -C local-repo commit -m initial

exec git -C local-repo push file://$MUGIT_REPO_DIR/httpclonerepo.git master

exec git clone $HTTP_URL/httpclonerepo clone-dir
exists clone-dir/README.md
exists clone-dir/hello.txt
exists clone-dir/src/main.go
exec cat clone-dir/hello.txt
stdout 'hello world'

-- README.md --
# Test Repo

A test repository.
-- hello.txt --
hello world
-- main.go --
package main

func main() {}
