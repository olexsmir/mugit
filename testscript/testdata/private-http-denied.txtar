# Private repo HTTP access denied
mkrepo privaterepo

git init local-repo
cp README.md local-repo/README.md
git -C local-repo add .
git -C local-repo commit -m initial

git -C local-repo push file://$REPOS/privaterepo.git master

mugit repo private privaterepo

! exec git clone $MURL/privaterepo private-clone

-- README.md --
