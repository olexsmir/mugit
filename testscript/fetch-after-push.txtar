# Fetch after push: push via filesystem, verify refs via HTTP ls-remote

git init local
cp file.txt local/file.txt
git -C local add file.txt
git -C local commit -m initial

mkrepo fetchafterrepo
git -C local push file://$REPOS/fetchafterrepo.git master


git ls-remote $MURL/fetchafterrepo
stdout 'refs/heads/master'

-- file.txt --
fetch test
