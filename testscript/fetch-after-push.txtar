# Fetch after push: push via filesystem, verify refs via HTTP ls-remote
mkrepo fetchafterrepo

git init local-repo
cp file.txt local-repo/file.txt
git -C local-repo add file.txt
git -C local-repo commit -m initial

git -C local-repo push file://$REPOS/fetchafterrepo.git master

exec git ls-remote $MURL/fetchafterrepo
stdout 'refs/heads/master'

-- file.txt --
fetch test
