# http: reject push

mkrepo http-push
exec git init local
exec git -C local config user.email "test@test.local"
exec git -C local config user.name "Test User"
cp file.txt local/file.txt
exec git -C local add file.txt
exec git -C local commit -m initial

! exec git -C local push $MURL/http-push.git master
stderr 'remote: pushes are only supported over ssh'

-- file.txt --
hello
